<idea-plugin>
    <!-- name, vendor, and description are injected by Gradle from gradle.properties and readme.md -->
    <id>com.saket.commentcontinuation</id>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
            parentId="tools"
            instance="com.saket.commentcontinuation.UserPreferencesScreen"
            id="com.saket.commentcontinuation.settings"
            displayName="Comment Continuation"/>
        <postStartupActivity
            implementation="com.saket.commentcontinuation.RegisterHandlerActivity"/>
    </extensions>
</idea-plugin>
